generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model Exercise {
  id          String   @id @default(cuid())
  title       String
  professorId String?
  studentId   String?
  lessonId    String?
  pdfName     String
  pdfData     String   // base64-encoded PDF bytes
  fieldsJson  String   @default("[]")
  answersJson String   @default("{}")        // { [fieldId]: value } saved by student
  status      String   @default("assigned") // assigned | in_progress | completed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  professor Professor? @relation(fields: [professorId], references: [id], onDelete: SetNull)
  student   Student?   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson    Lesson?    @relation(fields: [lessonId], references: [id], onDelete: SetNull)
}

model Professor {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  subject   String?
  bio       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students      Student[]
  lessons       Lesson[]
  learningPlans LearningPlan[]
  exercises     Exercise[]
}

model Student {
  id          String   @id @default(cuid())
  name        String
  email       String   @unique
  password    String
  enrollment  String?  @unique
  professorId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  professor         Professor?        @relation(fields: [professorId], references: [id])
  subjects          StudentSubject[]
  lessons           Lesson[]
  learningPlan      LearningPlan?
  vocabularyEntries VocabularyEntry[]
  exercises         Exercise[]
}

model Subject {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  students StudentSubject[]
  lessons  Lesson[]
}

model StudentSubject {
  studentId  String
  subjectId  String
  enrolledAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([studentId, subjectId])
}

model LearningPlan {
  id          String   @id @default(cuid())
  studentId   String   @unique
  professorId String?
  level       String
  objective   String
  bookRef     String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student   Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  professor Professor? @relation(fields: [professorId], references: [id])
}

model Lesson {
  id          String   @id @default(cuid())
  studentId   String
  professorId String?
  subjectId   String?
  scheduledAt DateTime
  meetLink    String?
  content     String?
  homework    String?
  notes       String?
  status      String   @default("SCHEDULED")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  student           Student           @relation(fields: [studentId], references: [id], onDelete: Cascade)
  professor         Professor?        @relation(fields: [professorId], references: [id])
  subject           Subject?          @relation(fields: [subjectId], references: [id])
  vocabularyEntries VocabularyEntry[]
  exercises         Exercise[]
}

model VocabularyEntry {
  id         String   @id @default(cuid())
  lessonId   String
  studentId  String
  word       String
  definition String?
  example    String?
  note       String?
  createdAt  DateTime @default(now())

  lesson  Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
}
